# Strapi API URL
# For local development: http://localhost:1337
# For production: https://your-strapi-url.com
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337

# Hero video URL (Cloudflare R2 or local fallback)
NEXT_PUBLIC_VIDEO_URL=https://assets.shamba.land/hero-background.mp4

# Resend (demo-request confirmation emails + audience) - https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# HubSpot CRM — demo-request leads land here as Contacts. Use a Private
# App access token (Settings → Integrations → Private Apps → CRM
# scopes: `crm.objects.contacts.read`, `crm.objects.contacts.write`).
# Standard `email` property only — we don't touch lifecyclestage /
# hs_lead_status / custom tags from the website. Lifecycle is owned
# by HubSpot CRM workflows downstream.
HUBSPOT_ACCESS_TOKEN=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: ArcGIS API key to use Esri's licensed basemap-styles on the plot map.
# Without it, the map uses keyless Esri World Imagery raster tiles (with attribution).
NEXT_PUBLIC_ARCGIS_API_KEY=
